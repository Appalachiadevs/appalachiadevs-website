{
    "rewrites": [
        {
            "source": "/iot/:path*",
            "destination": "https://iot.weienwong.online/:path*"
        },
        {
            "source": "/rag/:path*",
            "destination": "https://rag.weienwong.online/:path*"
        },
        {
            "source": "/guard/:path*",
            "destination": "https://guard.weienwong.online/:path*"
        },
        {
            "source": "/((?!assets/|portfolio/|_vercel/)(?!robots\\.txt$)(?!sitemap\\.xml$)(?!logo\\.svg$)(?!vite\\.svg$).*)",
            "destination": "/index.html"
        }
    ]
}